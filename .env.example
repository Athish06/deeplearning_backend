# Copy this file to .env and fill in real values.
# Do NOT commit .env to git.

# Use hosted low-memory inference backend (recommended for Render free tier)
SENTIMENT_BACKEND=hf_api
ALLOW_BACKEND_FALLBACK=true
HF_API_TIMEOUT=60

# Hugging Face token (keep secret)
HF_API_TOKEN=hf_your_token_here

# Optional override (default already points to SiEBERT)
# HF_API_URL=https://api-inference.huggingface.co/models/siebert/sentiment-roberta-large-english
